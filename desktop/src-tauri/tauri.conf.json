{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Godot MCP",
  "version": "1.0.0",
  "identifier": "dev.fulvio.godot-mcp",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "npm run bundle:server",
    "beforeBuildCommand": "npm run bundle:server"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Godot MCP",
        "width": 960,
        "height": 700,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "resources/server.cjs"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Manage the godot-mcp server and AI agents",
    "longDescription": "A small desktop control panel that supervises the godot-mcp-server (start/stop, status, logs) and launches AI coding agents pointed at it."
  }
}
